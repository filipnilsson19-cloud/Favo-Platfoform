generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  personal
}

model Recipe {
  id           String       @id
  title        String
  category     String
  status       String
  servings     Int          @default(1)
  updatedLabel String       @default("Importerad")
  allergens    String       @default("")
  notes        String       @default("")
  summary      String       @default("")
  intro        String       @default("")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  items        RecipeItem[]

  @@index([category])
  @@index([status])
  @@index([updatedAt])
  @@map("recipes")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@index([isActive])
  @@map("categories")
}

model StationView {
  id         String   @id @default(cuid())
  name       String
  scopeKey   String
  scopeLabel String
  recipeCount Int     @default(0)
  isActive   Boolean  @default(true)
  layout     Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([scopeKey, name])
  @@index([scopeKey, isActive])
  @@map("station_views")
}

model RecipeItem {
  id         String  @id @default(cuid())
  recipeId   String
  sortOrder  Int
  info       String  @default("")
  name       String
  amount     String
  unit       String  @default("g")
  isEmphasis Boolean @default(false)
  isSpacer   Boolean @default(false)
  recipe     Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId, sortOrder])
  @@map("recipe_items")
}

model UserProfile {
  id          String   @id
  email       String   @unique
  displayName String   @default("")
  role        UserRole @default(personal)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([role])
  @@map("user_profiles")
}
