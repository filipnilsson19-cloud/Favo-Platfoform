generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  personal
}

model Recipe {
  id           String       @id
  title        String
  category     String
  status       String
  servings     Int          @default(1)
  updatedLabel String       @default("Importerad")
  allergens    String       @default("")
  notes        String       @default("")
  summary      String       @default("")
  intro        String       @default("")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  items        RecipeItem[]
  costProfile  RecipeCostProfile?
  costLinks    RecipeItemCostLink[]

  @@index([category])
  @@index([status])
  @@index([updatedAt])
  @@map("recipes")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@index([isActive])
  @@map("categories")
}

model StationView {
  id         String   @id @default(cuid())
  name       String
  scopeKey   String
  scopeLabel String
  recipeCount Int     @default(0)
  isActive   Boolean  @default(true)
  layout     Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([scopeKey, name])
  @@index([scopeKey, isActive])
  @@map("station_views")
}

model RecipeItem {
  id         String  @id @default(cuid())
  recipeId   String
  sortOrder  Int
  info       String  @default("")
  name       String
  amount     String
  unit       String  @default("g")
  isEmphasis Boolean @default(false)
  isSpacer   Boolean @default(false)
  recipe     Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId, sortOrder])
  @@map("recipe_items")
}

model RecipeCostProfile {
  recipeId             String   @id
  sellingPriceInclVat  Decimal  @default(0) @db.Decimal(10, 2)
  vatRate              Decimal  @default(12) @db.Decimal(5, 2)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  recipe               Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("recipe_cost_profiles")
}

model RecipeItemCostLink {
  id               String         @id @default(cuid())
  recipeId         String
  itemIndex        Int
  sourceKind       CostSourceKind @default(raw)
  rawIngredientId  String?
  prepRecipeId     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  recipe           Recipe         @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  rawIngredient    RawIngredient? @relation(fields: [rawIngredientId], references: [id], onDelete: SetNull)
  prepRecipe       PrepRecipe?    @relation(fields: [prepRecipeId], references: [id], onDelete: SetNull)

  @@unique([recipeId, itemIndex])
  @@index([rawIngredientId])
  @@index([prepRecipeId])
  @@map("recipe_item_cost_links")
}

model UserProfile {
  id          String      @id
  email       String      @unique
  displayName String      @default("")
  role        UserRole    @default(personal)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  prepBatches PrepBatch[]

  @@index([role])
  @@map("user_profiles")
}

model PrepCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@index([isActive])
  @@map("prep_categories")
}

model PrepUnitOption {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@index([isActive])
  @@map("prep_unit_options")
}

model PrepStorageOption {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@index([isActive])
  @@map("prep_storage_options")
}

model PrepRecipe {
  id            String           @id @default(cuid())
  title         String
  category      String
  status        String           @default("Utkast")
  storage       String           @default("Kyl")
  shelfLifeDays Int              @default(3)
  defaultYield  String           @default("")
  yieldUnit     String           @default("")
  allergens     String           @default("")
  notes         String           @default("")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  ingredients   PrepIngredient[]
  steps         PrepStep[]
  batches       PrepBatch[]
  ingredientLinks PrepIngredientCostLink[]
  menuLinks     RecipeItemCostLink[]

  @@index([category])
  @@index([status])
  @@map("prep_recipes")
}

model PrepIngredient {
  id           String     @id @default(cuid())
  prepRecipeId String
  sortOrder    Int
  info         String     @default("")
  name         String
  amount       String
  unit         String     @default("g")
  prepRecipe   PrepRecipe @relation(fields: [prepRecipeId], references: [id], onDelete: Cascade)

  @@index([prepRecipeId, sortOrder])
  @@map("prep_ingredients")
}

model PrepIngredientCostLink {
  id              String         @id @default(cuid())
  prepRecipeId    String
  ingredientIndex Int
  rawIngredientId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  prepRecipe      PrepRecipe     @relation(fields: [prepRecipeId], references: [id], onDelete: Cascade)
  rawIngredient   RawIngredient? @relation(fields: [rawIngredientId], references: [id], onDelete: SetNull)

  @@unique([prepRecipeId, ingredientIndex])
  @@index([rawIngredientId])
  @@map("prep_ingredient_cost_links")
}

model PrepStep {
  id           String     @id @default(cuid())
  prepRecipeId String
  sortOrder    Int
  description  String
  prepRecipe   PrepRecipe @relation(fields: [prepRecipeId], references: [id], onDelete: Cascade)

  @@index([prepRecipeId, sortOrder])
  @@map("prep_steps")
}

model PrepBatch {
  id           String      @id @default(cuid())
  prepRecipeId String
  madeById     String
  madeAt       DateTime    @default(now())
  bestBefore   DateTime
  batchYield   String      @default("")
  notes        String      @default("")
  prepRecipe   PrepRecipe  @relation(fields: [prepRecipeId], references: [id])
  madeBy       UserProfile @relation(fields: [madeById], references: [id])

  @@index([prepRecipeId])
  @@index([bestBefore])
  @@map("prep_batches")
}

model RawIngredient {
  id             String                  @id @default(cuid())
  name           String                  @unique
  supplier       String                  @default("")
  purchasePrice  Decimal                 @default(0) @db.Decimal(10, 2)
  packageType    String                  @default("förpackning")
  packageCount   Decimal                 @default(1) @db.Decimal(10, 3)
  purchaseAmount Decimal                 @default(1) @db.Decimal(10, 3)
  purchaseUnit   String                  @default("kg")
  yieldPercent   Decimal                 @default(100) @db.Decimal(5, 2)
  notes          String                  @default("")
  isActive       Boolean                 @default(true)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  prepLinks      PrepIngredientCostLink[]
  recipeLinks    RecipeItemCostLink[]

  @@index([isActive, name])
  @@map("raw_ingredients")
}

enum CostSourceKind {
  raw
  prep
}
